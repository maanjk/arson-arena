rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'admin@arson.com' || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true));
    }
    
    function hasValidToken() {
      return request.auth != null && request.auth.token != null;
    }
    
    // Core Collections
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId); 
    }
    
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      // Admin full write; authenticated users can update (join/leave) but not create/delete
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated();

      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isOwner(participantId) || isAdmin());
      }
    }
    
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    match /leaderboards/{leaderboardType} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /system/{configType} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /notifications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /referral_codes/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /system_announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /_test/{docId} {
      allow read: if true;
    }

    // Catch-all for subcollections or other paths
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
